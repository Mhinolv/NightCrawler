# Claude API — used for article relevance filtering + detail extraction
ANTHROPIC_API_KEY=
# Optional; defaults to claude-haiku-4-5
ANTHROPIC_MODEL=

# HookDeck queue (optional). When unset, searches are processed in-process —
# fine for local dev. When set, POST /api/search publishes one event per
# state×keyword query to this HookDeck Source URL, and HookDeck delivers them
# to /api/jobs/search at the rate configured on the connection.
HOOKDECK_SOURCE_URL=
# Signing secret from the HookDeck dashboard; enables signature verification
# on /api/jobs/search. Strongly recommended once deployed.
HOOKDECK_SIGNING_SECRET=
